# 比赛平台用户工号，用于租房 API 请求头 X-User-ID
RENT_USER_ID=f00952481

# 租房仿真 API 地址
RENT_API_BASE=http://7.225.29.223:8080

# Agent 监听端口
AGENT_PORT=8190

# 日志级别：DEBUG / INFO
LOG_LEVEL=INFO

# 是否导出会话 Trace 到 logs/traces
ENABLE_TRACE_EXPORT=true

# 是否启用 API 重试
ENABLE_RETRY=true

# Trace 文件目录
TRACE_DIR=logs/traces
